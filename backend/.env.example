# LLM Provider: "groq" or "openai"
LLM_PROVIDER=groq

# API Keys
GROQ_API_KEY=your-groq-api-key-here
OPENAI_API_KEY=your-openai-api-key-here

# LLM Model
GROQ_MODEL=llama-3.3-70b-versatile
OPENAI_MODEL=gpt-4o-mini

# File Storage
UPLOAD_DIR=./uploads
CHART_DIR=./charts

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=true

# CORS
FRONTEND_URL=http://localhost:5173
